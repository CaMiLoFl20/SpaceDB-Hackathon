# Copy to .env.local and adjust if needed.
# Do not commit .env.local — it is gitignored.

# Vite client (required for npm run dev)
VITE_SPACETIMEDB_HOST=https://maincloud.spacetimedb.com
VITE_SPACETIMEDB_DB_NAME=market-sim-69q12

# Must exactly match your GitHub OAuth app's Authorization callback URL.
# Production (Vercel):
VITE_GITHUB_OAUTH_REDIRECT_URI=https://market-sim-wine.vercel.app
# Local dev (use only one callback URL in GitHub at a time, or create a second OAuth app):
# VITE_GITHUB_OAUTH_REDIRECT_URI=http://localhost:5173

# SpacetimeDB CLI (optional — spacetime.json also sets these)
SPACETIMEDB_HOST=https://maincloud.spacetimedb.com
SPACETIMEDB_DB_NAME=market-sim-69q12

# GitHub OAuth (optional — for Sign in with GitHub)
# Create a GitHub OAuth App at https://github.com/settings/developers
# Set Authorization callback URL to EXACTLY (no trailing slash):
#   https://market-sim-wine.vercel.app
# For local dev, temporarily change callback to http://localhost:5173
# and set VITE_GITHUB_OAUTH_REDIRECT_URI=http://localhost:5173 in .env.local
# Then run: spacetime call --server maincloud market-sim-69q12 set_github_oauth_config '"CLIENT_ID"' '"CLIENT_SECRET"'
